<Window x:Class="WpfApp.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Карточка номенклатуры" Height="280" Width="320"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="15">

        <TextBlock Text="Наименование позиции ТМЦ:" 
                   FontWeight="Bold"/>
        <TextBox x:Name="NameBox" 
                 Height="25" 
                 Margin="0,5,0,10"
                 VerticalContentAlignment="Center"/>

        <TextBlock Text="Базовая стоимость (ед.):" 
                   FontWeight="Bold"/>
        <TextBox x:Name="PriceBox" 
                 Height="25" 
                 Margin="0,5,0,10"
                 VerticalContentAlignment="Center"/>

        <TextBlock Text="Техническое описание / Спецификация:" 
                   FontWeight="Bold"/>
        <TextBox x:Name="DescBox" 
                 Height="25" 
                 Margin="0,5,0,20"
                 VerticalContentAlignment="Center"/>

        <Button Content="Сохранить позицию"
                Height="35"
                FontWeight="Bold"
                Click="Save_Click"/>
    </StackPanel>
</Window>
