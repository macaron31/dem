<Window x:Class="WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp"
        mc:Ignorable="d"
        Title="Панель управления снабжением B2B" Height="500" Width="850">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- КНОПКИ БЫСТРОГО ДЕЙСТВИЯ -->
        <StackPanel Orientation="Horizontal">

            <Button Content="Добавить поставщика"
                    Width="180"
                    Height="35"
                    Margin="0 0 10 10"
                    Click="AddPartner_Click"/>

            <Button Content="Добавить номенклатуру"
                    Width="180"
                    Height="35"
                    Margin="0 0 10 10"
                    Click="AddProduct_Click"/>

            <Button Content="Оформить закупку"
                    Width="180"
                    Height="35"
                    Margin="0 0 10 10"
                    Click="AddOrder_Click"/>

        </StackPanel>

        <!-- ТЕМАТИЧЕСКИЕ ВКЛАДКИ -->
        <TabControl Grid.Row="1">

            <!-- ПОСТАВЩИКИ -->
            <TabItem Header="База поставщиков">

                <DataGrid x:Name="PartnersGrid"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          MouseDoubleClick="PartnersGrid_MouseDoubleClick">

                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Добавить поставщика"
                                      Click="AddPartner_Click"/>
                            <MenuItem Header="Изменить данные"
                                      Click="EditPartner_Click"/>
                            <MenuItem Header="Исключить из базы"
                                      Click="DeletePartner_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>

                </DataGrid>

            </TabItem>

            <!-- НОМЕНКЛАТУРА -->
            <TabItem Header="Номенклатура склада">

                <DataGrid x:Name="ProductsGrid"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          MouseDoubleClick="ProductsGrid_MouseDoubleClick">

                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Добавить позицию"
                                      Click="AddProduct_Click"/>
                            <MenuItem Header="Редактировать цену/описание"
                                      Click="EditProduct_Click"/>
                            <MenuItem Header="Удалить позицию"
                                      Click="DeleteProduct_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>

                </DataGrid>

            </TabItem>

            <!-- ЗАКУПКИ / СДЕЛКИ -->
            <TabItem Header="Реестр закупок">

                <DataGrid x:Name="OrdersGrid"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          SelectionChanged="OrdersGrid_SelectionChanged">

                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Создать закупку"
                                      Click="AddOrder_Click"/>
                            <MenuItem Header="Изменить этап/статус"
                                      Click="EditOrder_Click"/>
                            <MenuItem Header="Аннулировать закупку"
                                      Click="DeleteOrder_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>

                </DataGrid>

            </TabItem>

        </TabControl>

        <!-- СПЕЦИФИКАЦИЯ ТЕКУЩЕЙ ЗАКУПКИ -->
        <GroupBox Grid.Row="2"
                  Header="Спецификация контролируемой поставки"
                  Margin="0 10 0 0">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Button Content="Включить товар в спецификацию"
                        Width="240"
                        Height="35"
                        Margin="10"
                        Click="AddOrderItem_Click"/>

                <DataGrid x:Name="OrderItemsGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="True"
                          IsReadOnly="True">

                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Изменить количество/стоимость"
                                      Click="EditOrderItem_Click"/>
                            <MenuItem Header="Удалить из спецификации"
                                      Click="DeleteOrderItem_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>

                </DataGrid>

            </Grid>

        </GroupBox>

    </Grid>
</Window>
